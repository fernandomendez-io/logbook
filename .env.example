# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-api-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # server-only — keep secret

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for invitation email links. Defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── FlightAware AeroAPI ───────────────────────────────────────────────────────
# Required for the "Fetch Times" feature (OOOI times + flight track data).
# Sign up at https://www.flightaware.com/aeroapi/portal
FLIGHTAWARE_API_KEY=<your-flightaware-aeroapi-key>
